    private void createMainMenu() {
    	    VBox menuLayout = new VBox(15);
    	    menuLayout.setAlignment(Pos.TOP_CENTER);
    	    menuLayout.setPadding(new Insets(30, 20, 20, 20));

    	   
    	    menuLayout.setPrefSize(900,700); 

    	    Label title = new Label("📦 Inventory Management");
    
    	    title.setStyle("-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white; -fx-background-color: rgba(0,0,0,0.5); -fx-padding: 10px;");

    	    Button btnAdd = new Button("Add Product");
    	    Button btnView = new Button("View Full Inventory");
    	    Button btnSearch = new Button("Search Product");
    	    Button btnUpdate = new Button("Update Product");
